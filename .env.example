# iCloud
APPLE_ID=your@apple.id
ALBUM_NAME=jinmu.me

# icloudpd container settings
ICLOUDPD_USER=user
ICLOUDPD_UID=1000
ICLOUDPD_GROUP=group
ICLOUDPD_GID=1000
DOWNLOAD_PATH=./photos
ICLOUD_INTERVAL=43200

# Telegram (for remote 2FA re-authentication via chatbot)
NOTIFICATION_TYPE=Telegram
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Cloudflare R2
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ACCOUNT_ID=
R2_BUCKET_NAME=
# optional, omit to upload to bucket root
R2_BUCKET_PREFIX=jinmu.me

# GitHub Actions dispatch (optional)
GITHUB_TOKEN=
GITHUB_REPO=
GITHUB_WORKFLOW=astro.yaml

# Sync settings
SYNC_INTERVAL=7200
TZ=Asia/Seoul
